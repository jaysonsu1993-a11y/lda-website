# LdA Website Deployment Configuration Template
# Copy this file to .env.deploy and fill in your actual values
# The .env.deploy file is gitignored and will NOT be uploaded to GitHub

# Aliyun Server
ALIYUN_SERVER="root@YOUR_SERVER_IP"
SERVER_PATH="/var/www/lda-website"
DEPLOY_PASS="your_password_here"

# Project Directory (usually auto-detected, no need to change)
# PROJECT_DIR="$HOME/.openclaw/workspace-crab/lda-website"
